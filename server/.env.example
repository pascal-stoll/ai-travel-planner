# TravelMind Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# LLM Provider Configuration
# Options: deepseek, gemini, openai, anthropic, openrouter
AI_PROVIDER=openrouter

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=15000

# API Keys - Configure at least one based on your AI_PROVIDER setting
# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini (Google's AI model - fast and capable)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Gemini API version override (v1beta or v1)
GEMINI_API_VERSION=v1beta
# Optional: Gemini model override when using Gemini provider
GEMINI_MODEL=gemini-1.5-flash
# Optional: fallback provider when the primary provider fails
# FALLBACK_AI_PROVIDER=deepseek

# OpenAI (high-quality responses)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (safety-focused)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter (compatible with OpenAI-style chat completions)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: OpenRouter model override when using OpenRouter provider
OPENROUTER_MODEL=gpt-4o-mini

# Optional: Logging Configuration (future enhancement)
# LOG_LEVEL=info
# LOG_FILE=logs/travelmind.log

# Optional: Database Configuration (future enhancement)
# DATABASE_URL=postgresql://user:password@localhost:5432/travelmind

# Optional: Redis Configuration (future enhancement for rate limiting)
# REDIS_URL=redis://localhost:6379
