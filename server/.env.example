# TravelMind Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:4173

# LLM Provider Configuration
# Options: deepseek, openai, anthropic
LLM_PROVIDER=deepseek

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=15000

# API Keys - Configure at least one based on your LLM_PROVIDER setting
# DeepSeek (recommended for development - cost-effective and fast)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI (high-quality responses)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (safety-focused)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Logging Configuration (future enhancement)
# LOG_LEVEL=info
# LOG_FILE=logs/travelmind.log

# Optional: Database Configuration (future enhancement)
# DATABASE_URL=postgresql://user:password@localhost:5432/travelmind

# Optional: Redis Configuration (future enhancement for rate limiting)
# REDIS_URL=redis://localhost:6379